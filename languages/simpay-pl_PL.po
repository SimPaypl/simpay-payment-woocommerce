#: ../../../../modules-dev/simpay-wordpress/src/Update/PluginUpdateChecker.php:51
#, php-format
msgid ""
"A new version of the SimPay for WooCommerce plugin is available. Current: "
"<strong>%1$s</strong>, latest: <strong>%2$s</strong>. <a href=\"%3$s\" "
"target=\"_blank\" rel=\"noopener noreferrer\">Download ZIP package</a>."
msgstr ""
"Dostępna jest nowa wersja wtyczki SimPay dla WooCommerce. Obecna: <strong>"
"%1$s</strong>, najnowsza: <strong>%2$s</strong>. <a href=\"%3$s\" "
"target=\"_blank\" rel=\"noopener noreferrer\">Pobierz paczkę ZIP</a>. "

#. Description of the plugin
msgid ""
"Accept fast and secure online payments with SimPay – BLIK, online transfers "
"and instant payments. Easy integration and smooth checkout for your "
"customers."
msgstr ""
"Akceptuj szybkie i bezpieczne płatności online z SimPay – BLIK, przelewy "
"online oraz płatności natychmiastowe. Prosta integracja i płynny proces "
"zakupu dla Twoich klientów."

